*.py[cod]
*$py.class

# Logs and temp files
*.log
*.tmp

# Editor and OS metadata
.DS_Store
.DS_Store?
Thumbs.db
*.swp
*.swo
*.bak

# Jupyter
.ipynb_checkpoints/

